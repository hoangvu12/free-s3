# free-s3 — example configuration. Copy to .env (git-ignored) and fill in.
# Every provider credential is OPTIONAL; a provider whose required credential is
# missing is skipped at startup (logged). At least one DURABLE provider must end
# up enabled or the gateway refuses to start.

# --- S3 gateway (required) --------------------------------------------------
S3_ACCESS_KEY_ID=free-s3-local
S3_SECRET_ACCESS_KEY=change-me-to-a-long-random-secret
LISTEN_ADDR=:9000
DATABASE_PATH=free-s3.db
# Public base URL for virtual-hosted addressing (optional; path-style always works).
# PUBLIC_ENDPOINT_URL=https://s3.example.com

# --- Replication / chunking -------------------------------------------------
REPLICATION_FACTOR=3            # R: distinct providers per chunk
CHUNK_SIZE=80MiB                # per-chunk window (under catbox's 200MB cap)
UPLOAD_CONCURRENCY=6            # parallel chunk-replica uploads
KEEPALIVE_INTERVAL=24h          # TTL-refresh / self-heal sweep cadence (0 = off)

# Enabled providers in priority order. Leave unset to use the built-in default
# (IA, fileditch, pixeldrain, catbox, x0.at, pomf.lain.la, paste.c-net.org,
# temp.sh, litterbox, tmpfiles.org, tmpfile.link, filebin.net, envs.sh, ttm.sh,
# fars.ee, uguu, tmp.ninja, doko.moe, cockfile). Add gofile/buzzheavier here
# once you've verified them from your deploy IP.
# FREEHOST_PROVIDERS=ia,fileditch,pixeldrain,catbox,x0.at,pomf.lain.la,temp.sh

# --- Per-provider credentials (all optional) --------------------------------
# catbox REQUIRES a userhash when uploading from a VPS/datacenter IP (anonymous
# uploads get HTTP 412 there). Get it from catbox.moe -> Manage Account.
# CATBOX_USERHASH=

# Pixeldrain API key (Account -> API keys). Without it pixeldrain still works
# anonymously but prunes inactive files faster.
# PIXELDRAIN_API_KEY=

# Internet Archive S3-like keys (archive.org/account/s3.php). Enables the
# permanent anchor; strongly recommended.
# IA_ACCESS_KEY=
# IA_SECRET_KEY=

# Gofile account token (gofile.io -> My Profile). REQUIRED for gofile to yield a
# raw hotlinkable direct link; gofile is skipped without it.
# GOFILE_TOKEN=

# --- Tuning (optional) ------------------------------------------------------
# STREAM_CONCURRENCY=4          # in-flight chunk fetches per GET
# STREAM_BUFFERS=8              # ordered delivery channel capacity
# STREAM_CHUNK_SIZE=4MiB        # reader prefetch window
# CHUNK_TIMEOUT=60s             # per-fetch timeout
# MULTIPART_TTL=168h            # abandoned multipart upload TTL
# MULTIPART_SWEEP_INTERVAL=1h   # multipart janitor cadence (0 = off)
# SQLITE_READER_CONNS=8
# HTTP_MAX_IDLE_CONNS_PER_HOST=32
